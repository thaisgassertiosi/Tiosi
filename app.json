{
  "expo": {
    "name": "Tiosi",
    "slug": "tiosi",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "web": {
      "bundler": "metro"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tiosi.app"
    },
    "android": {
      "package": "com.tiosi.app"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Tiosi saves a photo of your bowl in your library on this device only.",
          "cameraPermission": "Tiosi can photograph your bowl to save with your library entry."
        }
      ]
    ]
  }
}
